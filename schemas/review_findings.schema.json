{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.agent-workflow-standards/schemas/review_findings.schema.json",
  "title": "Review 发现",
  "type": "object",
  "required": [
    "task_id",
    "status",
    "blocking_findings",
    "non_blocking_findings"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "approved",
        "changes_requested",
        "blocked"
      ]
    },
    "blocking_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "non_blocking_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "suggested_tests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "required": [
        "id",
        "severity",
        "issue",
        "expected_fix",
        "evidence"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "blocking",
            "non_blocking"
          ]
        },
        "file": {
          "type": "string"
        },
        "lines": {
          "type": "string"
        },
        "issue": {
          "type": "string"
        },
        "expected_fix": {
          "type": "string"
        },
        "evidence": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
