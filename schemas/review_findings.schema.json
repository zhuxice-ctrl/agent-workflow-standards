{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.agent-workflow-standards/schemas/review_findings.schema.json",
  "type": "object",
  "required": ["schema", "task_id", "status", "review_basis", "blocking_findings", "non_blocking_findings", "suggested_tests", "risk_notes"],
  "properties": {
    "schema": {"const": "ADworkflo.review_findings.v1"},
    "task_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["not_reviewed", "approved", "changes_requested", "blocked"]},
    "reviewer": {"type": ["string", "null"]},
    "source_revision": {"type": ["string", "integer", "null"]},
    "review_basis": {"type": "array", "items": {"type": "string"}},
    "blocking_findings": {"type": "array", "items": {"$ref": "#/$defs/finding"}},
    "non_blocking_findings": {"type": "array", "items": {"$ref": "#/$defs/finding"}},
    "suggested_tests": {"type": "array", "items": {"type": "string"}},
    "risk_notes": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "finding": {
      "type": "object",
      "required": ["id", "severity", "issue", "expected_fix", "evidence"],
      "properties": {
        "id": {"type": "string"},
        "severity": {"enum": ["blocking", "non_blocking"]},
        "issue": {"type": "string"},
        "expected_fix": {"type": "string"},
        "evidence": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "approved"}}},
      "then": {"properties": {"reviewer": {"type": "string", "minLength": 1}, "source_revision": {"not": {"type": "null"}}, "blocking_findings": {"maxItems": 0}}}
    }
  ],
  "additionalProperties": true
}
