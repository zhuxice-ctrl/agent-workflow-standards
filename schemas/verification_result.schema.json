{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.agent-workflow-standards/schemas/verification_result.schema.json",
  "type": "object",
  "required": ["schema", "task_id", "status", "commands", "acceptance_criteria_coverage", "passed", "failed", "not_run_reason", "residual_risk"],
  "properties": {
    "schema": {"const": "ADworkflo.verification_result.v1"},
    "task_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["passed", "failed", "partial", "not_run"]},
    "source_revision": {"type": ["string", "integer", "null"]},
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command", "status", "summary"],
        "properties": {
          "command": {"type": "string"},
          "status": {"enum": ["passed", "failed", "not_run"]},
          "summary": {"type": "string"},
          "exit_code": {"type": ["integer", "null"]}
        },
        "additionalProperties": true
      }
    },
    "acceptance_criteria_coverage": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["criterion", "status", "evidence"],
        "properties": {
          "criterion": {"type": "string"},
          "status": {"enum": ["passed", "failed", "not_run"]},
          "evidence": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },
    "passed": {"type": "array", "items": {"type": "string"}},
    "failed": {"type": "array", "items": {"type": "string"}},
    "not_run_reason": {"type": ["string", "null"]},
    "residual_risk": {"type": "array", "items": {"type": "string"}}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "passed"}}},
      "then": {"properties": {"source_revision": {"not": {"type": "null"}}, "not_run_reason": {"type": "null"}}}
    }
  ],
  "additionalProperties": true
}
