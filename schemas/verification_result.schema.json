{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.agent-workflow-standards/schemas/verification_result.schema.json",
  "title": "验证结果",
  "type": "object",
  "required": [
    "task_id",
    "status",
    "commands",
    "passed",
    "failed"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "partial",
        "not_run"
      ]
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command",
          "status"
        ],
        "properties": {
          "command": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "not_run"
            ]
          },
          "summary": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "passed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "not_run_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "residual_risk": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
