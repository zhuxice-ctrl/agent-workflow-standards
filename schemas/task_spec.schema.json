{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.agent-workflow-standards/schemas/task_spec.schema.json",
  "type": "object",
  "required": ["schema", "configured", "task_id", "task_type", "goal", "non_goals", "acceptance_criteria", "risk_level", "execution_mode", "allowed_actions", "required_outputs", "do_not_touch", "entrypoints", "context_sources"],
  "properties": {
    "schema": {"const": "ADworkflo.task_spec.v2"},
    "configured": {"type": "boolean"},
    "task_id": {"type": "string"},
    "task_type": {"enum": ["code", "product", "architecture", "workflow", "docs", "review"]},
    "goal": {"type": "string"},
    "non_goals": {"type": "array", "items": {"type": "string"}},
    "acceptance_criteria": {"type": "array", "items": {"type": "string"}},
    "risk_level": {"enum": ["low", "medium", "high"]},
    "execution_mode": {"enum": ["solo_worker", "worker_plus_reviewer", "fanout_workers"]},
    "allowed_actions": {"type": "array", "items": {"enum": ["read", "edit", "test", "shell", "network"]}},
    "required_outputs": {"type": "array", "items": {"type": "string"}},
    "do_not_touch": {"type": "array", "items": {"type": "string"}},
    "entrypoints": {"type": "array", "items": {"type": "string"}},
    "context_sources": {"type": "array", "items": {"type": "string"}},
    "notes": {"type": "array", "items": {"type": "string"}}
    ,"implementation_owner": {"type": ["string", "null"]}
  },
  "allOf": [
    {
      "if": {"properties": {"configured": {"const": true}}},
      "then": {
        "properties": {
          "task_id": {"type": "string", "minLength": 1, "not": {"const": "unconfigured"}},
          "goal": {"type": "string", "minLength": 1},
          "acceptance_criteria": {"type": "array", "minItems": 1}
        }
      }
    }
  ],
  "additionalProperties": true
}
